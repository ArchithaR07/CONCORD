{
  "$id": "obligation.schema.json",
  "description": "Output of L1 EXTRACT + L2 LENS. One row per extracted obligation. This is the contract A1 ships to A2 (L3 filtering) and B (L11/L12/L15/L16).",
  "type": "object",
  "required": ["id", "policy_file", "section", "obligation", "action", "scope",
               "strength", "topic", "raw_text", "embedding"],
  "properties": {
    "id": {"type": "string", "example": "obl_0042"},
    "policy_file": {"type": "string", "example": "policy_01.md"},
    "policy_name": {"type": "string", "example": "Password Policy"},
    "department": {"type": "string", "example": "Product"},
    "section": {"type": "string", "example": "3"},
    "last_reviewed": {"type": "string", "format": "date", "example": "2023-03-28"},
    "status": {"type": "string", "example": "active"},
    "obligation": {"type": "string", "example": "password_require"},
    "action": {"type": "string", "enum": ["REQUIRE", "PROHIBIT", "RECOMMEND", "PERMIT"]},
    "scope": {
      "type": "object",
      "required": ["department", "geography", "system_type", "raw_scope_text"],
      "properties": {
        "department": {"type": "array", "items": {"type": "string"}},
        "geography": {"type": "array", "items": {"type": "string"}},
        "system_type": {"type": "array", "items": {"type": "string"}},
        "raw_scope_text": {"type": "string"}
      }
    },
    "strength": {"type": "string", "enum": ["mandatory", "recommended", "optional"]},
    "frequency": {"type": ["string", "null"], "example": "90_days"},
    "topic": {"type": "string", "example": "password"},
    "external_mandate": {"type": ["string", "null"], "example": "GDPR Article 17"},
    "deprecated_reference": {"type": ["string", "null"], "example": "TLS 1.0"},
    "raw_text": {"type": "string"},
    "extraction_method": {"type": "string", "enum": ["rule_template", "rule_fallback", "llm_structured"]},
    "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "embedding": {"type": "array", "items": {"type": "number"}},
    "embedding_backend": {"type": "string", "example": "tfidf+svd"},
    "tfidf_keywords": {"type": "array", "items": {"type": "string"}}
  }
}
