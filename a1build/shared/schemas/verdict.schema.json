{
  "$id": "verdict.schema.json",
  "description": "Shape BOTH Rule Bench (A2, rule_verdicts.json) and LLM Bench (A1, llm_verdicts.json) must emit for the same candidate pair. L5 (A1) joins on obligation_a_id/obligation_b_id across both files.",
  "candidate_pair": {
    "description": "Output of L3 FILTER (A2 owns this in the real build; l3_candidates_stub.py mimics it for standalone A1 testing).",
    "type": "object",
    "required": ["obligation_a_id", "obligation_b_id", "policy_a", "policy_b", "topic", "embedding_similarity"],
    "properties": {
      "obligation_a_id": {"type": "string"},
      "obligation_b_id": {"type": "string"},
      "policy_a": {"type": "string"},
      "policy_b": {"type": "string"},
      "topic": {"type": "string"},
      "same_topic": {"type": "boolean"},
      "embedding_similarity": {"type": "number", "minimum": -1, "maximum": 1}
    }
  },
  "rule_verdict": {
    "type": "object",
    "required": ["obligation_a_id", "obligation_b_id", "verdict", "rule_signal"],
    "properties": {
      "obligation_a_id": {"type": "string"},
      "obligation_b_id": {"type": "string"},
      "verdict": {"type": "string", "enum": ["CONFLICT", "REDUNDANT", "COMPLEMENTARY", "UNRELATED", "ESCALATE"]},
      "rule_signal": {"type": "number", "enum": [0.0, 0.5, 1.0]},
      "basis": {"type": "string", "example": "opposite_action_same_scope"}
    }
  },
  "llm_verdict": {
    "type": "object",
    "required": ["obligation_a_id", "obligation_b_id", "verdict", "confidence"],
    "properties": {
      "obligation_a_id": {"type": "string"},
      "obligation_b_id": {"type": "string"},
      "verdict": {"type": "string", "enum": ["CONFLICT", "REDUNDANT", "COMPLEMENTARY", "UNRELATED"]},
      "confidence": {"type": "number", "minimum": 0, "maximum": 1},
      "scope_analysis": {"type": "string"},
      "explanation": {"type": "string"},
      "recommendation": {"type": "string"}
    }
  }
}
