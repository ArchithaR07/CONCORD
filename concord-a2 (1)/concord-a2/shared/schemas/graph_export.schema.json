{
  "$id": "graph_export.schema.json",
  "title": "GraphExport",
  "description": "Output of L8 MESH + L9 CENTRALITY (A2). Person B's L13 ATLAS graph view and L16 SYNOD grouping build against this file.",
  "type": "object",
  "required": ["nodes", "edges", "generated_at", "params"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "policy", "section", "topic", "keystone_score"],
        "properties": {
          "id": { "type": "string" },
          "policy": { "type": "string" },
          "doc_id": { "type": "string" },
          "section": { "type": "string" },
          "topic": { "type": "string" },
          "degree": { "type": "integer" },
          "betweenness": { "type": "number" },
          "keystone_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "is_keystone": { "type": "boolean" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "trust_score", "finding_type"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "trust_score": { "type": "number" },
          "finding_type": { "type": "string" },
          "finding_id": { "type": "string" }
        }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "params": {
      "type": "object",
      "description": "Parameters the graph was built with, so B's dashboard can display/replay them.",
      "properties": {
        "keystone_top_pct": { "type": "number" }
      }
    }
  }
}
